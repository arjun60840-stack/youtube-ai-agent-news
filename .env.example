# =============================================================
# AI Daily News YouTube Agent — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# =============================================================

# --- Ollama Settings ---
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Text-to-Speech Settings ---
# Available voices: en-US-GuyNeural, en-US-JennyNeural, en-GB-RyanNeural
TTS_VOICE=en-IN-PrabhatNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# --- YouTube API Settings ---
# Path to your OAuth client secrets file (download from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS=config/client_secrets.json
# Path where the OAuth token will be cached after first authorization
YOUTUBE_TOKEN_PATH=config/youtube_token.json
# Upload privacy: private, unlisted, or public
YOUTUBE_PRIVACY=private
# YouTube category ID (28 = Science & Technology)
YOUTUBE_CATEGORY=28

# --- Channel Branding ---
CHANNEL_NAME=AI Daily News

# --- FFmpeg ---
# Path to FFmpeg executable (just "ffmpeg" if it's on your PATH)
FFMPEG_PATH=ffmpeg

# --- RSS Feeds ---
# Comma-separated list of Google News RSS feed URLs
# Leave empty to use default technology/AI feeds
RSS_FEEDS=
